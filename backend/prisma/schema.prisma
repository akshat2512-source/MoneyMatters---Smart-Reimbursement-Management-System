generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }

model Company {
  id           String         @id @default(uuid())
  name         String
  currency     String
  country      String
  createdAt    DateTime       @default(now())
  users        User[]
  approvalRules ApprovalRule[]
}

model User {
  id                String   @id @default(uuid())
  name              String
  email             String   @unique
  password          String
  role              Role     @default(EMPLOYEE)
  companyId         String
  managerId         String?
  isManagerApprover Boolean  @default(false)
  company           Company  @relation(fields: [companyId], references: [id])
  manager           User?    @relation("Mgr", fields: [managerId], references: [id])
  employees         User[]   @relation("Mgr")
  expenses          Expense[]
  approvalSteps     ApprovalStep[]
  createdAt         DateTime @default(now())
}

enum Role { ADMIN MANAGER EMPLOYEE }

model Expense {
  id            String        @id @default(uuid())
  amount        Float
  currency      String
  amountInBase  Float
  category      String
  description   String
  date          DateTime
  status        ExpenseStatus @default(PENDING)
  receiptUrl    String?
  submittedById String
  submittedBy   User          @relation(fields: [submittedById], references: [id])
  approvalSteps ApprovalStep[]
  createdAt     DateTime      @default(now())
}

enum ExpenseStatus { PENDING APPROVED REJECTED IN_REVIEW }

model ApprovalRule {
  id                 String           @id @default(uuid())
  companyId          String
  company            Company          @relation(fields: [companyId], references: [id])
  name               String
  type               ApprovalRuleType
  percentage         Int?
  specificApproverId String?
  steps              ApprovalRuleStep[]
}

enum ApprovalRuleType { SEQUENTIAL PERCENTAGE SPECIFIC_APPROVER HYBRID }

model ApprovalRuleStep {
  id         String       @id @default(uuid())
  ruleId     String
  rule       ApprovalRule @relation(fields: [ruleId], references: [id])
  approverId String
  sequence   Int
}

model ApprovalStep {
  id         String             @id @default(uuid())
  expenseId  String
  expense    Expense            @relation(fields: [expenseId], references: [id])
  approverId String
  approver   User               @relation(fields: [approverId], references: [id])
  sequence   Int
  status     ApprovalStepStatus @default(PENDING)
  comment    String?
  decidedAt  DateTime?
}

enum ApprovalStepStatus { PENDING APPROVED REJECTED SKIPPED }
